{
  "metadata": {
    "spec-version": "1.0"
  },
  "configuration-groups": [
    {
      "label": "Configuration",
      "properties": [
        {
          "widget-type": "select",
          "label": "Header Format",
          "name": "headerFormat",
          "description": "The expected format of the FASTQ header.",
          "widget-attributes": {
            "values": [
              "Auto-Detect",
              "Illumina Casava 1.8+",
              "Legacy Illumina",
              "Oxford Nanopore"
            ],
            "default": "Auto-Detect"
          }
        },
        {
          "widget-type": "textbox",
          "label": "Input Field",
          "name": "sequence_header",
          "description": "The name of the input field containing the FASTQ header string.",
          "widget-attributes": {
            "default": "sequence_header"
          }
        }
      ]
    }
  ],
  "outputs": [
    {
      "name": "schema",
      "widget-type": "schema",
      "widget-attributes": {
        "schema": "FastqHeaderNormalizer"
      }
    }
  ]
}